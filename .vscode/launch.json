{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Debug Relay",
      "type": "go",
      "request": "launch",
      "mode": "auto",
      "program": "${workspaceFolder}",
      "console": "integratedTerminal",
      "args": ["--ip", "0.0.0.0", "--port", "49983"]
    },
    {
      "name": "Debug Relay (custom port)",
      "type": "go",
      "request": "launch",
      "mode": "auto",
      "program": "${workspaceFolder}",
      "console": "integratedTerminal",
      "args": ["--ip", "0.0.0.0", "--port", "${input:port}"]
    }
  ],
  "inputs": [
    {
      "id": "port",
      "type": "promptString",
      "description": "UDP port to listen on",
      "default": "49983"
    }
  ]
}
